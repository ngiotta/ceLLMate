<UserControl x:Class="LLMContextVS.ToolWindows.LLMChatWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LLMContextVS.ToolWindows"
             mc:Ignorable="d" 
             d:DesignHeight="520" d:DesignWidth="520"
             Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Chat area -->
            <RowDefinition Height="Auto"/>  <!-- Input -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6" Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}">
            <ComboBox x:Name="ContextModeCombo" Width="140" Margin="0,0,6,0" ToolTip="Default context attached to messages"
                      SelectedIndex="3" SelectionChanged="ContextModeCombo_SelectionChanged">
                <ComboBoxItem Content="No context"/>
                <ComboBoxItem Content="Current file"/>
                <ComboBoxItem Content="Selection"/>
                <ComboBoxItem Content="Full solution"/>
                <ComboBoxItem Content="Open documents"/>
            </ComboBox>

            <Button x:Name="ClearChatBtn" Content="Clear Chat" Margin="0,0,4,0" Padding="8,2" Click="ClearChatBtn_Click"/>
            <Button x:Name="HistoryBtn" Content="📜" Width="28" Click="HistoryBtn_Click" ToolTip="Chat history" Margin="2,0"/>
            <Button x:Name="SettingsBtn" Content="⚙ Settings" Margin="4,0,0,0" Padding="8,2" Click="SettingsBtn_Click"/>

            <TextBlock x:Name="ContextStats" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
        </StackPanel>

        <!-- Chat Messages -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" Padding="6"
                          Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                <StackPanel x:Name="MessagesPanel" />
            </ScrollViewer>

            <Border x:Name="HistoryPanel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="300"
                    Margin="0,8,8,8"
                    Padding="8"
                    Background="White"
                    BorderBrush="#CCC"
                    BorderThickness="1"
                    CornerRadius="4"
                    Panel.ZIndex="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock Text="Chat History" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="CloseHistoryBtn"
                                DockPanel.Dock="Right"
                                Width="24"
                                Height="24"
                                Content="✕"
                                Click="CloseHistoryBtn_Click"
                                ToolTip="Close history panel"/>
                    </DockPanel>

                    <ListBox x:Name="HistoryListBox"
                             Grid.Row="1"
                             Margin="0,8,0,0"
                             SelectionChanged="HistoryListBox_SelectionChanged"
                             DisplayMemberPath="DisplayText"/>

                    <TextBlock x:Name="HistoryEmptyText"
                               Grid.Row="2"
                               Margin="0,8,0,0"
                               Foreground="#666"
                               Text="No saved chat sessions yet."
                               Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Input area -->
        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputBox" 
                         AcceptsReturn="True" 
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="60" 
                         TextWrapping="Wrap"
                         KeyDown="InputBox_KeyDown"
                         Margin="0,0,6,0"
                         ToolTip="Type your question. Press Ctrl+Enter to send with selected context."/>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                    <Button x:Name="SendBtn" Content="Send" Width="70" Height="26" Margin="0,0,0,4" Click="SendBtn_Click"/>
                    <Button x:Name="CancelBtn" Content="Cancel" Width="70" Height="26" IsEnabled="False" Click="CancelBtn_Click"/>
                    <Button x:Name="SendFullBtn" Content="Send + Full" Width="70" Height="26" ToolTip="Force send using full solution context" Click="SendFullBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status -->
        <Border Grid.Row="3" Background="#F0F0F0" Padding="4,2">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Text="Ready. Configure endpoint &amp; model in Tools → Options → ceLLMate" FontSize="10" VerticalAlignment="Center"/>
                <TextBlock x:Name="TokenHint" Margin="12,0,0,0" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
